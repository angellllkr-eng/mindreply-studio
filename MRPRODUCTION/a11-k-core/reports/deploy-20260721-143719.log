PS C:\Users\ANGEL\MRPRODUCTION\a11-k-core> try {
  Step "Checking required commands"
  Need git
  Need pnpm
  Need vercel
  Ok "git, pnpm, and vercel found"

  Step "Checking git state"
  $branch = git branch --show-current
  $commit = git rev-parse --short HEAD

  Write-Host "Branch: $branch"
  Write-Host "Commit: $commit"

  $status = git status --short
  if ($status) {
    Warn "Working tree has uncommitted changes:"
    Write-Host $status
    Warn "Review this if unexpected. Continuing because local staged work may be intentional."
  } else {
    Ok "Working tree clean"
  }

  Step "Checking Vercel linkage"

  if (Test-Path ".vercel\project.json") {
    $projectJson = Get-Content ".vercel\project.json" -Raw | ConvertFrom-Json

    if ($projectJson.projectName) {
      Write-Host "Linked Vercel project: $($projectJson.projectName)"

      if ($projectJson.projectName -ne $ExpectedProject) {
        throw "Wrong Vercel project. Linked '$($projectJson.projectName)', expected '$ExpectedProject'. Stopping."
      }

      Ok "Vercel project matches expected project: $ExpectedProject"
    } else {
      Warn ".vercel/project.json found but projectName not present. Verify manually."
    }
  } else {
    throw "Project not linked. Run 'vercel link' manually and choose project '$ExpectedProject' first."
  }

  Step "Checking .env.example safety"

  if (Test-Path ".env.example") {
    $envExample = Get-Content ".env.example" -Raw

    $suspicious = @(
      "sk-",
      "sk_ant",
      "sk-ant",
      "postgresql://",
      "://user:password",
      "secure-token",
      "generated-secure"
    )

    $hit = $false

    foreach ($needle in $suspicious) {
      if ($envExample -like "*$needle*") {
        $hit = $true
        Warn ".env.example contains suspicious placeholder/value pattern: $needle"
      }
    }

    if (-not $hit) {
      Ok ".env.example appears to contain key names only"
    }
  } else {
    Warn ".env.example not found"
  }

  Step "Running local build"
  pnpm build
  Ok "pnpm build passed"

  if ($SkipDeploy) {
    Warn "SkipDeploy supplied. No deployment attempted."
  } else {
    Step "Deploying ONCE to Vercel production"
    Warn "If Vercel quota is still exhausted, this will fail. This script will not retry."

    $deployOut = "reports\vercel-deploy-$timestamp.out.txt"
    $deployErr = "reports\vercel-deploy-$timestamp.err.txt"

    $process = Start-Process `
      -FilePath "vercel" `
      -ArgumentList "--prod", "--yes" `
      -NoNewWindow `
      -Wait `
      -PassThru `
      -RedirectStandardOutput $deployOut `
      -RedirectStandardError $deployErr

    $stdout = Get-Content $deployOut -Raw -ErrorAction SilentlyContinue
    $stderr = Get-Content $deployErr -Raw -ErrorAction SilentlyContinue

    Write-Host "Vercel stdout:"
    Write-Host $stdout

    if ($stderr) {
      Write-Host "Vercel stderr:"
      Write-Host $stderr
    }

    if ($process.ExitCode -ne 0) {
      Fail "Vercel deploy failed with exit code $($process.ExitCode). No retry attempted."

      if (($stderr + $stdout) -match "limit|quota|rate") {
        Warn "Likely Vercel quota/rate/deployment limit. Wait for reset or upgrade Vercel, then rerun once."
      }

      throw "Deployment failed"
    }

    $deploymentUrl = ($stdout -split "`n" | Where-Object { $_ -match "https://" } | Select-Object -Last 1).Trim()

    if ($deploymentUrl) {
      Ok "Deployment URL: $deploymentUrl"
      Set-Content -Path "reports\last-deployment-url.txt" -Value $deploymentUrl
    } else {
      Warn "Could not parse deployment URL from stdout. Check $deployOut"
    }
  }

  if ($SkipVerify) {
    Warn "SkipVerify supplied. Live URL checks skipped."
  } else {
    Step "Verifying live URLs"

    $urls = @(
      "https://www.mind-reply.com/",
      "https://a11-k.space/",
      "https://a11-k.space/command",
      "https://brushworks.a11-k.space/",
      "https://sql.mind-reply.com/",
      "https://tools.mind-reply.com/",
      "https://labs.a11-k.space/"
    )

    $results = @()

    foreach ($url in $urls) {
      try {
        $resp = Invoke-WebRequest -Uri $url -MaximumRedirection 5 -TimeoutSec 20 -UseBasicParsing

        $title = ""
        if ($resp.Content -match "<title>(.*?)</title>") {
          $title = $matches[1]
        }

        $row = [PSCustomObject]@{
          Url = $url
          StatusCode = [int]$resp.StatusCode
          Title = $title
          Notes = "responded"
        }

        Write-Host "$url => $($row.StatusCode) $($row.Title)"
        $results += $row
      } catch {
        $row = [PSCustomObject]@{
          Url = $url
          StatusCode = "ERROR"
          Title = ""
          Notes = $_.Exception.Message
        }

        Warn "$url => ERROR $($_.Exception.Message)"
        $results += $row
      }
    }

    $jsonPath = "reports\live-verify-$timestamp.json"
    $results | ConvertTo-Json -Depth 4 | Set-Content $jsonPath
    Ok "Verification saved: $jsonPath"
  }

  Step "Final status"
  Ok "Script completed. Log: $LogPath"
}
finally {
  Stop-Transcript | Out-Null
}

