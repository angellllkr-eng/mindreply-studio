# Agent Control Plane Environment
# Place this in your user profile or load it before running agents

# Suppress upgrade prompts
GROK_NO_UPDATE_CHECK=1
CLAUDE_NO_UPDATE_CHECK=1
FORCE_COLOR=0
NO_COLOR=1

# API Keys (loaded from migration kit)
# XAI_API_KEY= (loaded from grok config)
# ANTHROPIC_API_KEY= (loaded from claude config)

# Ports
ACP_PORT=4747
OPEN_WEBUI_PORT=8890
GROK_PROXY_PORT=4747
