# Environment Variables for MindReply
# Copy to .env and fill in real secrets for production

# Database
DB_PASSWORD=mindreply_dev_password
DATABASE_URL=postgresql://mindreply_user:mindreply_dev_password@postgres:5432/mindreply

# Frontend
NODE_ENV=production
PORT=3000
VITE_API_URL=http://localhost:3000/api

# Backend Services
OPENAI_API_KEY=sk-your-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# N8N
N8N_WEBHOOK_URL=http://n8n:5678/webhook

# Salesforce
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Security
JWT_SECRET=mindreply_jwt_dev_secret_change_in_production
CORS_ORIGIN=http://localhost:3000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MCP Server
MCP_PORT=3001

# Admin UI (PgAdmin)
PGADMIN_PASSWORD=admin
